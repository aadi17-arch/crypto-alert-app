# Firebase Web App API key from Firebase Console -> Project Settings -> General
REACT_APP_FIREBASE_API_KEY=your_api_key_here

# Firebase Auth domain, usually your-project.firebaseapp.com
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase project ID from Project Settings
REACT_APP_FIREBASE_PROJECT_ID=your_project_id_here

# Firebase Storage bucket value
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Firebase Cloud Messaging sender ID
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here

# Firebase app ID for your web app
REACT_APP_FIREBASE_APP_ID=your_app_id_here
